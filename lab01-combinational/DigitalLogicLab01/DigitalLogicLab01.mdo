if {![file exists "C:/KTU/SEMESTER 2/First Principal Oof Digital Logic/Lattice Diamond/DigitalLogicLab01/DigitalLogicLab01.mpf"]} { 
	project new "C:/KTU/SEMESTER 2/First Principal Oof Digital Logic/Lattice Diamond/DigitalLogicLab01" DigitalLogicLab01
	project addfile "C:/KTU/SEMESTER 2/First Principal Oof Digital Logic/Lattice Diamond/impl1/DigitalLogicLab01.vhd"
	vlib  work
	vdel -lib work -all 
	vlib work
	vcom -work work "C:/KTU/SEMESTER 2/First Principal Oof Digital Logic/Lattice Diamond/impl1/DigitalLogicLab01.vhd"
} else {
	project open "C:/KTU/SEMESTER 2/First Principal Oof Digital Logic/Lattice Diamond/DigitalLogicLab01/DigitalLogicLab01"
